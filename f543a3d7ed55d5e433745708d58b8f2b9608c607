        "id": 5015
      },
      "writtenOn": "2018-04-18T19:16:05Z",
      "side": 1,
      "message": "It\u0027s short for \"target\", meaning that the specified destination is exactly where the source ends up.  Contrast with the default behavior which is that, if the specified destination is a directory, the source gets copied INTO that directory, rather than replacing it (actually, I think you get an error with -T if the destination already exists).",
      "parentUuid": "54924cb8_bcb88178",
      "range": {
        "startLine": 210,
        "startChar": 54,
        "endLine": 210,
        "endChar": 55
      },

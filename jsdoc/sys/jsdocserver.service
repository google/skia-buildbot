[Unit]
Description=jsdocserver
Wants=network-online.target
After=network-online.target

[Service]
ExecStart=/usr/local/bin/jsdocserver \
    --git_repo_dir=/mnt/pd0/skia \
    --logtostderr
Restart=always
User=default
Group=default
LimitNOFILE=10000
Environment=PATH=/usr/local/bin:/usr/bin:/bin:/home/default/node/bin:/home/default/.yarn/bin

[Install]
WantedBy=multi-user.target

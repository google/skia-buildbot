{
  port: ":9091",
  prom_port: ":20000",
  pubsub_event_topic: "gold-chrome-gpu-migration-eventbus-bt",
  pubsub_project_id: "skia-public",

  ingestion_configs: {
    // Primary Ingester
    gold_bt: {
      backup_poll_every: "1h",
      backup_poll_last_n_commits: 5,
      backup_poll_last_n_hours: 2,
      // This reads from the old skia-gold-chrome-gpu bucket and writes to the new chrome instance.
      // We will reingest all data here on the primary branch.
      gcs_sources: [
        {
          bucket: "skia-gold-chrome-gpu",
          prefix: "dm-json-v1"
        }
      ],
      extra_configuration: {
        BTProjectID: "skia-public",
        BTInstance: "production",
        BTTable: "gold-chrome"
      }
    },
    // This reads from the old skia-gold-chrome-gpu bucket and writes to the new chrome instance.
    // We will reingest data from the last 90 days for tryjobs.
    gold_tryjob_fs: {
      backup_poll_every: "1h",
      backup_poll_last_n_hours: 2,
      gcs_sources: [
        {
          bucket: "skia-gold-chrome-gpu",
          prefix: "trybot/dm-json-v1"
        },
      ],
      extra_configuration: {
        FirestoreProjectID: "skia-firestore",
        FirestoreNamespace: "chrome",

        CodeReviewSystems: "gerrit",
        GerritURL:         "https://chromium-review.googlesource.com",

        ContinuousIntegrationSystems: "buildbucket",
      }
    }
  }
}

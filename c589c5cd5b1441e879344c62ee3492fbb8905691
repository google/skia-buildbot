      "writtenOn": "2020-04-13T04:41:54Z",
      "side": 1,
      "message": "Please use keydown. It\u0027s a non-standard behavior for a UI to react to when the user releases a key, as opposed to reacting immediately when a user presses down a key.\n\nTake for example Gerrit and the line selection behavior when pressing the up/down arrow keys. Note that the action happens when said keys are pressed down, as opposed to when they\u0027re released.",
      "range": {
        "startLine": 200,
        "startChar": 31,
        "endLine": 200,
        "endChar": 36
      },
      "revId": "c589c5cd5b1441e879344c62ee3492fbb8905691",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

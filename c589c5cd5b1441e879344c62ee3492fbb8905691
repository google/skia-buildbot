      },
      "lineNbr": 200,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-04-13T12:51:10Z",
      "side": 1,
      "message": "[citation needed] https://medium.com/@uistephen/keyboardevent-key-for-cross-browser-key-press-check-61dbad0a067a",
      "parentUuid": "1cc74483_a6ca6202",
      "range": {
        "startLine": 200,
        "startChar": 31,
        "endLine": 200,
        "endChar": 36
      },
      "revId": "c589c5cd5b1441e879344c62ee3492fbb8905691",

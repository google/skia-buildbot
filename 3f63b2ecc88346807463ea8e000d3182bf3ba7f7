    {
      "key": {
        "uuid": "6c4d0915_950ec930",
        "filename": "status/go/incremental/comments.go",
        "patchSetId": 6
      },
      "lineNbr": 131,
      "author": {
        "id": 5120
      },
      "writtenOn": "2017-09-21T02:13:26Z",
      "side": 1,
      "message": "Currently none of the DB impls pays attention to the time cutoff passed to GetCommentsForRepos. If they did, this test would fail anytime a comment expires from the window. Is that intended?",
      "range": {
        "startLine": 131,
        "startChar": 6,
        "endLine": 131,
        "endChar": 82
      },
      "revId": "3f63b2ecc88346807463ea8e000d3182bf3ba7f7",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "e96437f6_ad9196e9",
        "filename": "status/go/incremental/comments.go",
        "patchSetId": 6
      },
      "lineNbr": 131,
      "author": {
        "id": 5015
      },
      "writtenOn": "2017-09-21T15:18:59Z",
      "side": 1,
      "message": "Yes, that\u0027s intended.  Unlike with tasks, we can\u0027t just pass the newly-added comments to the client, since we may have removed comments as well.  I played with implementing lists of added and removed comments, but given the relatively low volume of comments it was far simpler to just pass the full set of comments every time it changed.  That said, the volume of comments is far higher than it could be, because of the time cutoff not having an effect :)",
      "parentUuid": "6c4d0915_950ec930",
      "range": {
        "startLine": 131,
        "startChar": 6,
        "endLine": 131,
        "endChar": 82
      },
      "revId": "3f63b2ecc88346807463ea8e000d3182bf3ba7f7",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

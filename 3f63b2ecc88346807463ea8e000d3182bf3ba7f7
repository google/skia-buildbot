    {
      "key": {
        "uuid": "8bfaace0_084bd0b4",
        "filename": "status/go/incremental/comments.go",
        "patchSetId": 6
      },
      "lineNbr": 121,
      "author": {
        "id": 5015
      },
      "writtenOn": "2017-09-21T15:18:59Z",
      "side": 1,
      "message": "Personally, I think the number of comments and rate of change in comments are low enough to just pass the whole set around every time it changes.",
      "parentUuid": "07126272_259ff9d5",
      "range": {
        "startLine": 121,
        "startChar": 24,
        "endLine": 121,
        "endChar": 48
      },

      },
      "writtenOn": "2020-02-18T14:19:43Z",
      "side": 1,
      "message": "The new name is more clear, but I think this interface leaks a little anyway (expectations.Label is a paramater after all).",
      "parentUuid": "c4e8f9b4_f88eec2a",
      "range": {
        "startLine": 70,
        "startChar": 1,
        "endLine": 70,
        "endChar": 19
      },
      "revId": "dce10d223b35ebe2caab71080d40aca46e1fb49d",

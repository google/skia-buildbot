      },
      "writtenOn": "2018-09-19T12:36:36Z",
      "side": 1,
      "message": "OK, but what does \"git remote set-url --push origin\" do?",
      "parentUuid": "bde0782c_3436e0df",
      "range": {
        "startLine": 31,
        "startChar": 0,
        "endLine": 49,
        "endChar": 11
      },
      "revId": "46580c0d8a7c6d5f27a0759b44c149a70d596f2d",

load("//bazel/go:go_test.bzl", "go_test")

# Generated by Bazel, then manually edited as follows:
#  - Tagged as "manual", because we only want to run this test via the wrapper script.
#  - Granted visibility to the wrapper script.
go_test(
    name = "wrapped_test",
    srcs = ["wrapped_test.go"],
    tags = ["manual"],
    visibility = ["//switchboard/bazelexamples/wrapper:__subpackages__"],
    deps = [
        "//go/testutils/unittest",
        "@com_github_stretchr_testify//require",
    ],
)

go_test(
    name = "wrapped_test_test",
    srcs = ["wrapped_test.go"],
    deps = [
        "//go/testutils/unittest",
        "@com_github_stretchr_testify//require",
    ],
)

    {
      "key": {
        "uuid": "9bfd6839_4912ab68",
        "filename": "task_scheduler/go/types/repo_state.go",
        "patchSetId": 5
      },
      "lineNbr": 139,
      "author": {
        "id": 5015
      },
      "writtenOn": "2018-12-19T14:24:59Z",
      "side": 1,
      "message": "I was hoping to save a lot of characters this way.  In practice, we\u0027ll run into failures before this point if we try to schedule tasks for any project not in REPO_PROJECT_MAPPING, so this seems relatively safe.  Added a fallback to use the full repo if it\u0027s not in REPO_PROJECT_MAPPING.  I also considered trying to shorten the repo URL, something like ${host}/${repo}, ie. \"https://skia.googlesource.com/skia.git\" -\u003e \"skia/skia\" or \"http://chromium.googlesource.com/chromium/tools/depot_tools.git\" -\u003e \"chromium/tools/depot_tools\".  But that seemed like more work than necessary, given that we already have human-generated short names for all of the repos we schedule.",
      "parentUuid": "cc80767d_19e27fb2",
      "range": {
        "startLine": 139,
        "startChar": 2,
        "endLine": 139,
        "endChar": 74
      },
      "revId": "04d80085bb9583d119902dd4f4cfc07138b296af",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

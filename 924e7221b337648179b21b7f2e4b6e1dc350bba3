    {
      "key": {
        "uuid": "77e194ce_60c12be7",
        "filename": "infra-sk/modules/page_object/page_object_element.ts",
        "patchSetId": 8
      },
      "lineNbr": 91,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-07-07T12:47:14Z",
      "side": 1,
      "message": "I\u0027m not sure what\u0027s idiomatic TypeScript for a situation like this. All I know is that in Go, when a type assertion fails, it panics (or returns false), so errors like this are not quiet.",
      "parentUuid": "e7e01b2d_fe10af08",
      "range": {
        "startLine": 91,
        "startChar": 7,
        "endLine": 91,
        "endChar": 30
      },
      "revId": "924e7221b337648179b21b7f2e4b6e1dc350bba3",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true

      "message": "bikeshed: applyFnToSelectorAll",
      "range": {
        "startLine": 177,
        "startChar": 8,
        "endLine": 177,
        "endChar": 12
      },
      "revId": "924e7221b337648179b21b7f2e4b6e1dc350bba3",

      "writtenOn": "2017-09-25T17:10:23Z",
      "side": 1,
      "message": "This is an \"off-line\" process, so it\u0027s not as time critical and updates in short succession will just result in no-ops (with some networking overhead). \nThat said I could move the secondary repo into the Ingester itself and then the update would run at the same frequency as the primary.",
      "parentUuid": "62eb98c1_86dd7da8",
      "range": {
        "startLine": 112,
        "startChar": 27,
        "endLine": 112,
        "endChar": 33
      },

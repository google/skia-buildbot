      "writtenOn": "2019-01-24T15:15:47Z",
      "side": 1,
      "message": "An alternative would be to have Put*InChunks return either a slice of the successfully-inserted tasks/jobs or the index of the last-successfully-inserted task/job so that the caller can handle partial insertions like this.",
      "range": {
        "startLine": 458,
        "startChar": 2,
        "endLine": 464,
        "endChar": 3
      },
      "revId": "e5e77616bba36d91d1bf360dea000a7e7ac5a129",

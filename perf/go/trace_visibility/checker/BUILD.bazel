load("@rules_go//go:def.bzl", "go_library")
load("//bazel/go:go_test.bzl", "go_test")

go_library(
    name = "checker",
    srcs = ["checker.go"],
    importpath = "go.skia.org/infra/perf/go/trace_visibility/checker",
    visibility = ["//visibility:public"],
    deps = [
        "//go/metrics2",
        "//go/skerr",
        "//go/sklog",
        "//perf/go/trace_visibility/provider",
        "//perf/go/trace_visibility/store",
    ],
)

go_test(
    name = "checker_test",
    srcs = ["checker_test.go"],
    embed = [":checker"],
    deps = [
        "//perf/go/trace_visibility/provider/mocks",
        "//perf/go/trace_visibility/sqlconfigstore/schema",
        "//perf/go/trace_visibility/store/mocks",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
        "@com_github_stretchr_testify//require",
    ],
)

load("@rules_pkg//:pkg.bzl", "pkg_tar")

# These pkg_tar targets strip the external/... prefix from the CIPD package
# contents and place them in tar files to be used in Docker images.

pkg_tar(
    name = "cipd_tar",
    srcs = ["@cipd_linux-amd64//:all_files"],
    package_dir = "/cipd",
    remap_paths = {"external/+cipd+cipd_linux-amd64/": ""},
    strip_prefix = ".",
    visibility = ["//visibility:public"],
)


      "unresolved": true
    },
    {
      "key": {
        "uuid": "57a4f274_2d27eb88",
        "filename": "run.go",
        "patchSetId": 2
      },
      "lineNbr": 22,
      "author": {
        "id": 5015
      },
      "writtenOn": "2018-09-25T12:03:08Z",
      "side": 1,
      "message": "IMO we need to have something closer to a normal program.  With a static list of steps it\u0027s much harder to do things like use the output of one step in a subsequent step, branching (eg. if dir doesn\u0027t exist, run \"git clone\"), etc.",
      "parentUuid": "7e810d6c_2352f3f8",
      "revId": "8099fde41beff266a3d35f0ce31323713173c3fd",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

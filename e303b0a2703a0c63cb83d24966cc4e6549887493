      "writtenOn": "2019-10-07T20:26:40Z",
      "side": 1,
      "message": "Why split these out into 4 fields?",
      "range": {
        "startLine": 18,
        "startChar": 3,
        "endLine": 18,
        "endChar": 11
      },
      "revId": "e303b0a2703a0c63cb83d24966cc4e6549887493",

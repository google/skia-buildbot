        "uuid": "3530530d_a8402a5d",
        "filename": "status/build_docker_release",
        "patchSetId": 2
      },
      "lineNbr": 22,
      "author": {
        "id": 5205
      },
      "writtenOn": "2018-06-29T16:51:04Z",
      "side": 1,
      "message": "Use ${INSTALL_DIR} here.\nAlso vertically align the ${ROOT}\u0027s.\nWhy not copy to /usr/local/bin?",
      "parentUuid": "97d16ba6_989ffff4",
      "range": {
        "startLine": 22,
        "startChar": 0,
        "endLine": 22,
        "endChar": 54
      },
      "revId": "90c78696d4cd4ab4531011ecd6375a9efaf5af6b",

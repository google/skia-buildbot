    {
      "key": {
        "uuid": "fa978580_687a1e4d",
        "filename": "status/build_docker_release",
        "patchSetId": 2
      },
      "lineNbr": 22,
      "author": {
        "id": 5015
      },
      "writtenOn": "2018-06-29T17:14:13Z",
      "side": 1,
      "message": "Per live discussion, the install command doesn\u0027t recursively copy directories; we\u0027ll have to use cp.  The CIPD package for git includes a number of files, and the binaries are under a \u0027bin\u0027 dir.  So I can\u0027t just copy to /usr/local/bin; I\u0027d have to pull the binaries out from the \u0027bin\u0027 subdir, and I didn\u0027t want to get too fiddly.  It\u0027s easy enough to add the dir to PATH.",
      "parentUuid": "3530530d_a8402a5d",
      "range": {
        "startLine": 22,
        "startChar": 0,
        "endLine": 22,
        "endChar": 54
      },
      "revId": "90c78696d4cd4ab4531011ecd6375a9efaf5af6b",

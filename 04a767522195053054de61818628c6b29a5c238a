      "writtenOn": "2021-02-22T22:00:16Z",
      "side": 1,
      "message": "I expected to see footers used everywhere here instead of trailers. \"trailers footer\" is especially confusing.\nIIRC, \"trailers\" is used in git, but in the context of what is trailing in a commit message, it could be anything not just things that match that regex.\nGerrit almost exclusively uses the term \"footer\": https://gerrit.googlesource.com/gerrit/+/v2.11-rc0/Documentation/config-gerrit.txt#3343",
      "range": {
        "startLine": 204,
        "startChar": 3,
        "endLine": 204,
        "endChar": 16
      },
      "revId": "04a767522195053054de61818628c6b29a5c238a",

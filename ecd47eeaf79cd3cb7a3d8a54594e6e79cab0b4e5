      "message": "Why is this necessary?  To avoid leaks?",
      "range": {
        "startLine": 180,
        "startChar": 28,
        "endLine": 180,
        "endChar": 42
      },
      "revId": "ecd47eeaf79cd3cb7a3d8a54594e6e79cab0b4e5",

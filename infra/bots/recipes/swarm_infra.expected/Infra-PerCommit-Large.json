[
  {
    "cmd": [
      "which",
      "go"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "which go"
  },
  {
    "cmd": [
      "go",
      "get"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "go get"
  },
  {
    "cmd": [
      "sudo",
      "npm",
      "i",
      "-g",
      "bower@1.8.2"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "install bower"
  },
  {
    "cmd": [
      "./setup_test_db"
    ],
    "cwd": "[START_DIR]/buildbot/go/database",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "setup database"
  },
  {
    "cmd": [
      "./run_emulator",
      "start"
    ],
    "cwd": "[START_DIR]/buildbot/go/ds/emulator",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "start the cloud data store emulator"
  },
  {
    "cmd": [
      "python",
      "-u",
      "[START_DIR]/buildbot/scripts/find_missing_go_deps.py",
      "--json"
    ],
    "env": {
      "BIGTABLE_EMULATOR_HOST": "localhost:8892",
      "CHROME_HEADLESS": "1",
      "DATASTORE_EMULATOR_HOST": "localhost:8891",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>",
      "PUBSUB_EMULATOR_HOST": "localhost:8893"
    },
    "name": "Find missing Go DEPS",
    "stdout": "/path/to/tmp/"
  },
  {
    "cmd": [
      "go",
      "run",
      "./run_unittests.go",
      "--alsologtostderr",
      "--large"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "BIGTABLE_EMULATOR_HOST": "localhost:8892",
      "CHROME_HEADLESS": "1",
      "DATASTORE_EMULATOR_HOST": "localhost:8891",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>:[DEPOT_TOOLS]",
      "PUBSUB_EMULATOR_HOST": "localhost:8893",
      "SKIABOT_TEST_DEPOT_TOOLS": "[DEPOT_TOOLS]"
    },
    "name": "run_unittests"
  },
  {
    "cmd": [
      "./run_emulator",
      "stop"
    ],
    "cwd": "[START_DIR]/buildbot/go/ds/emulator",
    "env": {
      "BIGTABLE_EMULATOR_HOST": "localhost:8892",
      "CHROME_HEADLESS": "1",
      "DATASTORE_EMULATOR_HOST": "localhost:8891",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>:[DEPOT_TOOLS]",
      "PUBSUB_EMULATOR_HOST": "localhost:8893",
      "SKIABOT_TEST_DEPOT_TOOLS": "[DEPOT_TOOLS]"
    },
    "name": "stop the cloud data store emulator"
  },
  {
    "jsonResult": null,
    "name": "$result"
  }
]
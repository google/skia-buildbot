[
  {
    "cmd": [
      "which",
      "go"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "which go"
  },
  {
    "cmd": [
      "go",
      "get"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "go get"
  },
  {
    "cmd": [
      "sudo",
      "npm",
      "i",
      "-g",
      "bower@1.8.2"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "install bower"
  },
  {
    "cmd": [
      "./setup_test_db"
    ],
    "cwd": "[START_DIR]/buildbot/go/database",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "setup database"
  },
  {
    "cmd": [
      "python",
      "-u",
      "[START_DIR]/buildbot/scripts/find_missing_go_deps.py",
      "--json"
    ],
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "Find missing Go DEPS",
    "stdout": "/path/to/tmp/"
  },
  {
    "cmd": [
      "go",
      "get",
      "github.com/hashicorp/go-multierror"
    ],
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "Sync missing github.com/hashicorp/go-multierror"
  },
  {
    "cmd": [
      "go",
      "get",
      "github.com/cenkalti/backoff"
    ],
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>"
    },
    "name": "Sync missing github.com/cenkalti/backoff"
  },
  {
    "cmd": [
      "go",
      "run",
      "./run_unittests.go",
      "--alsologtostderr",
      "--small"
    ],
    "cwd": "[START_DIR]/buildbot",
    "env": {
      "CHROME_HEADLESS": "1",
      "GIT_USER_AGENT": "git/1.9.1",
      "GOCACHE": "[START_DIR]/cache/go_cache",
      "GOROOT": "[START_DIR]/go/go",
      "PATH": "[START_DIR]/go/go/bin:[START_DIR]/gcloud_linux/bin:[START_DIR]/protoc/bin:[START_DIR]/node/node/bin:<PATH>:[DEPOT_TOOLS]",
      "SKIABOT_TEST_DEPOT_TOOLS": "[DEPOT_TOOLS]"
    },
    "name": "run_unittests"
  },
  {
    "jsonResult": null,
    "name": "$result"
  }
]
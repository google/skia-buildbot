    {
      "key": {
        "uuid": "4a143406_a730381b",
        "filename": "gitsync/cmd/gitsync/watcher.go",
        "patchSetId": 52
      },
      "lineNbr": 82,
      "author": {
        "id": 5015
      },
      "writtenOn": "2019-02-22T17:56:13Z",
      "side": 1,
      "message": "Per our in-person conversation, I don\u0027t think timestamps are a reliable way to ensure that we\u0027ve ingested all of the commits.  I think you\u0027d be better off using git.Repo directly and following a similar procedure to repograph:\n1. Perform a git fetch\n2. List the new branch heads\n3. Compare the new branch heads to the old; for each branch, if the head commit has changed:\n  a. If the new head of the branch is a descendant of the old: use git rev-list to find the new hashes\n  b. If the new head is not a descendant of the old, then history has changed. Use git rev-list to load hashes until we find one we\u0027ve seen before.\n  c. Load the details for the new hashes.\n4. Push the new commit details and branch heads into BigTable.\n5. If we hit 3b, force a re-index.\n\nThat procedure is here: https://skia.googlesource.com/buildbot/+/master/go/git/repograph/graph.go#245",
      "range": {
        "startLine": 82,
        "startChar": 1,
        "endLine": 82,
        "endChar": 10
      },
      "revId": "cbc5f4a089ccc410dad8be6400c0204ac7d5ea2d",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
    {

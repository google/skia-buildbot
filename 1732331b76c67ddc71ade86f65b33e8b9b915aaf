      },
      "writtenOn": "2019-01-31T13:21:37Z",
      "side": 1,
      "message": "This should be \"master\"; there\u0027s no guarantee that HEAD points to the tip of master, or even that it points to any commit on master at all.  In general we should prefer not to assume anything about the checkout (including that it exists at all) and only query the index.",
      "range": {
        "startLine": 97,
        "startChar": 12,
        "endLine": 97,
        "endChar": 18
      },
      "revId": "1732331b76c67ddc71ade86f65b33e8b9b915aaf",

    {
      "key": {
        "uuid": "2e73d6da_604abaf4",
        "filename": "go/git/gitinfo/gitinfo.go",
        "patchSetId": 9
      },
      "lineNbr": 97,
      "author": {
        "id": 5620
      },
      "writtenOn": "2019-01-31T15:23:02Z",
      "side": 1,
      "message": "I thought so too. But by calling Checkout() and then Update() you can switch to different branches. At this point I don\u0027t want to change that so I don\u0027t break code depending on it, but make the BigTable based version clearer in terms of what branch someone is on.",
      "parentUuid": "6d797191_33de2d3a",
      "range": {
        "startLine": 97,
        "startChar": 12,
        "endLine": 97,
        "endChar": 18
      },
      "revId": "1732331b76c67ddc71ade86f65b33e8b9b915aaf",

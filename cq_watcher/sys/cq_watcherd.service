[Unit]
Description=Watches over the CQ and alerts unusual behavior.
Wants=network-online.target
After=network-online.target

[Service]
ExecStart=/usr/local/bin/prober \
    --log_dir=/var/log/logserver
Restart=always
User=default
Group=default
LimitNOFILE=10000

[Install]
WantedBy=multi-user.target

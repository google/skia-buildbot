    {
      "key": {
        "uuid": "f59ee309_925f3e93",
        "filename": "skolo/go/powercycle/command_runner.go",
        "patchSetId": 6
      },
      "lineNbr": 79,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-04-16T20:08:00Z",
      "side": 1,
      "message": "CombinedOutput is an example from the standard library where the primary value can be used even if the error is non-nil.  Since we call that directly, I think it\u0027s ok to mirror that idiom.\n\nAdditionally, skerr.Wrapf adds details about the stacktrace; I think it is more clear to keep the error and stdout/stderr separate, so it\u0027s easier to know what the executable said and what golang added on.",
      "parentUuid": "20c48f87_564c0db9",
      "range": {
        "startLine": 79,
        "startChar": 0,
        "endLine": 79,
        "endChar": 58
      },

      "writtenOn": "2020-04-16T17:43:11Z",
      "side": 1,
      "message": "The vast majority of code ignores the primary return value(s) if a non-nil error is returned. Could we include the output of the command in the error message instead?",
      "range": {
        "startLine": 79,
        "startChar": 0,
        "endLine": 79,
        "endChar": 58
      },
      "revId": "8caad67ca859f751b9e91c8c12ffea5cca92aed2",

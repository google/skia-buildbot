        "uuid": "c44c42f4_e2f71c8d",
        "filename": "perf/modules/calendar-sk/calendar-sk_test.ts",
        "patchSetId": 22
      },
      "lineNbr": 31,
      "author": {
        "id": 10009
      },
      "writtenOn": "2020-06-29T21:57:06Z",
      "side": 1,
      "message": "Overall suggestions:\n\n- Use setUpElementUnderTest(), which cleans up the EUT for you and requires less code.\n- No need to wait until the custom element is defined; the import order guarantees this.\n- Use eventPromise() to catch events with less code, written in async/await style.\n- Extract out any code using query selectors into high-level helper functions at the end of the outermost describe block.\n\nThe last suggestion leads to shorter and more declarative tests, e.g.:\n\n  clickDateBtn(19);\n\nvs.\n\n  calendarSk.querySelector\u003cHTMLButtonElement\u003e(\u0027button[data-date\u003d\"19\"]\u0027)!.click();\n\nLumping all such helpers together at the end of the describe block means you\u0027ll only have to look in one place if you change the component\u0027s markup in the future and the selectors break.\n\nThis is what this file might look like after applying the above suggestions:\n\n  describe(\u0027calendar-sk\u0027, () \u003d\u003e {\n    const newInstance \u003d setUpElementUnderTest\u003cCalendarSk\u003e(\u0027calendar-sk\u0027);\n\n    let calendarSk: CalendarSk;\n\n    beforeEach(() \u003d\u003e {\n      calendarSk \u003d newInstance();\n      calendarSk.displayDate \u003d new Date(2020, 4, 21);\n    });\n\n    describe(\u0027event\u0027, () \u003d\u003e {\n      it(\u0027fires when button is clicked\u0027, async () \u003d\u003e {\n        const event \u003d eventPromise\u003cCustomEvent\u003cCalendarSkChangeEventDetails\u003e\u003e(\u0027change\u0027);\n        clickDateBtn(19);\n        const detail \u003d (await event).detail;\n\n        assert.equal(\n          new Date(2020, 4, 19).toDateString(),\n          detail.date.toDateString(),\n          \u0027Date has changed.\u0027);\n      });\n    });\n\n    // ...\n\n  });",
      "range": {
        "startLine": 5,
        "startChar": 0,
        "endLine": 31,
        "endChar": 5
      },
      "revId": "287e77e36b2ff8eb4bcb6c2e5e1112f2e308508f",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

#!/bin/bash
APPNAME=fuzzer-be

set -x -e

# Run CIPD to obtain git.
CIPD_ROOT="/tmp/basedebian_cipd"
cipd ensure -root=${CIPD_ROOT} -ensure-file ../kube/basedebian/cipd.ensure

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="install -D --verbose --backup=none"
${INSTALL} --mode=644 -T ${APPNAME}/Dockerfile    ${ROOT}/Dockerfile
${INSTALL} --mode=755 -T ${GOPATH}/bin/${APPNAME} ${ROOT}/${APPNAME}
cp -r                    ${CIPD_ROOT}             ${ROOT}/cipd
}

source ../bash/docker_build.sh

#!/bin/bash
# Builds and uploads a debian package for prober.
APPNAME=proberd

set -x -e

build_probers_json5 --dest=allprobers.json5

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="install -D --verbose"
${INSTALL} --mode=644 -T docker/Dockerfile        ${ROOT}/Dockerfile
${INSTALL} --mode=755 -T ${GOPATH}/bin/prober     ${ROOT}/prober
${INSTALL} --mode=644 -T ./allprobers.json5       ${ROOT}/allprobers.json5
}

source ../bash/docker_push.sh

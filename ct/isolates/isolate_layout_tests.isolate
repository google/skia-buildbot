{
  'includes': [
    'py.isolate',
  ],
  'conditions': [
    ['OS=="linux"', {
      'variables': {
        'files': [
          '../../../../../bin/isolate_layout_tests',
        ],
        'command': [
          '../../../../../bin/isolate_layout_tests',
          '-logtostderr',
          '--run_id=<(RUN_ID)',
          '--chromium_hash=<(CHROMIUM_HASH)',
          '--out=${ISOLATED_OUTDIR}',
        ],
      },
    }],
  ]
}

      },
      "writtenOn": "2019-09-06T17:15:56Z",
      "side": 1,
      "message": "Checking my understanding: the difference in performance between using the raw bytes vs. the hex-encoded bytes is not worth the extra difficulty in debugging, because any performance difference in map lookups would be swamped by the DB activity, and the extra space/network needed is swamped by the size of the other data, e.g. ResultParams.",
      "range": {
        "startLine": 415,
        "startChar": 8,
        "endLine": 415,
        "endChar": 26
      },
      "revId": "3cf5dccca3072dd8e1ba36cbd575fb4fd92f7d49",

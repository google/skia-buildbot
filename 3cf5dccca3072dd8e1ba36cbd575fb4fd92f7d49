      "writtenOn": "2019-09-06T17:15:56Z",
      "side": 1,
      "message": "nit: Seems like we might want to use GetAll to retrieve all the params at once: https://godoc.org/cloud.google.com/go/firestore#Client.GetAll\n\n(Not sure if it would be faster/better to use sharded queries or fetch individually in goroutines.)",
      "range": {
        "startLine": 213,
        "startChar": 0,
        "endLine": 213,
        "endChar": 39
      },
      "revId": "3cf5dccca3072dd8e1ba36cbd575fb4fd92f7d49",

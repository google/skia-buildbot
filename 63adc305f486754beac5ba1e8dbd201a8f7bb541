      "writtenOn": "2017-10-13T18:42:49Z",
      "side": 1,
      "message": "nit: ISTM this should be either p.BeginningOfTime or p.lastSuccess.Add(-p.Window)",
      "range": {
        "startLine": 64,
        "startChar": 29,

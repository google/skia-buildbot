        "id": 5620
      },
      "writtenOn": "2017-05-19T18:34:21Z",
      "side": 1,
      "message": "I like the current setup where all GCE creation-related code is in one folder. It allows to see our footprint in one place.  IMO deployment should be detached from the application code.",
      "range": {
        "startLine": 1,
        "startChar": 0,
        "endLine": 1,
        "endChar": 12
      },
      "revId": "25cbb8152bc2c6a023cd75a1b6e58285da5091d8",

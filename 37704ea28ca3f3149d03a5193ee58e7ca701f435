      "writtenOn": "2019-11-19T13:18:24Z",
      "side": 1,
      "message": "I\u0027d recommend styling \u003csmall\u003e in your CSS so it\u0027s consistent across browsers",
      "range": {
        "startLine": 41,
        "startChar": 23,
        "endLine": 41,

#!/bin/bash
# Builds and uploads a debian package for prober.
APPNAME=proberk

set -x -e

build_probersk_json5 --dest=allprobersk.json5

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="sudo install -D --verbose --backup=none --group=root --owner=root"
${INSTALL} --mode=644 -T Dockerfile                ${ROOT}/Dockerfile
${INSTALL} --mode=755 -T ${GOPATH}/bin/prober     ${ROOT}/bin/prober
}

source ../bash/docker_build.sh

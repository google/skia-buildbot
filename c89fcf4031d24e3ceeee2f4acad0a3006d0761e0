      "key": {
        "uuid": "c4e03996_8ecdccdd",
        "filename": "autoroll/go/repo_manager/github_repo_manager.go",
        "patchSetId": 44
      },
      "lineNbr": 176,
      "author": {
        "id": 5145
      },
      "writtenOn": "2018-04-19T13:17:35Z",
      "side": 1,
      "message": "This is necessary to get the forked repo to be the same as the target repo to prepare it for the pull request. It is especially useful if the forked repo contains changes that were never merged into the target repo and needs to be thrown away. This step basically resets the forked repo.\n\nWithout it the push command fails with:\ngit push origin roll_branch; Stdout+Stderr:\\nTo github.com:rmistry/engine.git\\n ! [rejected]            roll_branch -\u003e roll_branch (non-fast-forward)\\nerror: failed to push some refs to \u0027git@github.com:rmistry/engine.git\u0027\\nhint: Updates were rejected because the tip of your current branch is behind\\nhint: its remote counterpart. Integrate the remote changes (e.g.\\nhint: \u0027git pull ...\u0027) before pushing again.\\nhint: See the \u0027Note about fast-forwards\u0027 in \u0027git push --help\u0027 for details.\\n\"",
      "parentUuid": "e2a022f8_d660d3f7",
      "range": {
        "startLine": 176,
        "startChar": 83,
        "endLine": 176,
        "endChar": 87
      },

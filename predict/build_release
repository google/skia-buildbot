#!/bin/bash
APPNAME=predict
set -x -e

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="fakeroot install -D --verbose --backup=none"
INSTALL_DIR="fakeroot install -d --verbose --backup=none"
${INSTALL}     --mode=755 -T ${GOPATH}/bin/${APPNAME} ${ROOT}/usr/local/bin/${APPNAME}
${INSTALL_DIR} --mode=755                             ${ROOT}/usr/local/share/${APPNAME}/templates
${INSTALL}     --mode=644    ./templates/*            ${ROOT}/usr/local/share/${APPNAME}/templates
}

source ../bash/docker_build.sh

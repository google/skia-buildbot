      "writtenOn": "2018-09-28T14:52:42Z",
      "side": 1,
      "message": "I am assuming every step needs a name, maybe it should be a required argument. instead of \".Name(...)\".\n\".Env(env)\" is debatable as a required argument because you do not always need to specify an env.",
      "range": {
        "startLine": 91,
        "startChar": 15,
        "endLine": 91,
        "endChar": 22
      },
      "revId": "623adc3efbde9e3daece6e8fc1b01d1742375182",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true

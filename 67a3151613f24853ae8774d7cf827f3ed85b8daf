      "side": 1,
      "message": "Would it work to do something like:\nn :\u003d w.numCommits\nhead :\u003d r.Get(\"master\")\nstopErr :\u003d errors.New(\"stop\")\nerr :\u003d head.Recurse(func(c *Commit) (bool, error) {\n  if c.Timestamp.Before(start) {\n    start \u003d c.Timestamp\n  }\n  n--\n  if n \u003c\u003d 0 {\n    return false, stopErr\n  }\n  return true, nil\n}\nif err !\u003d stopErr {\n  return err\n}\n\nOr if you want to be pedantic:\nrecurse :\u003d func(c *Commit, n int) time.Time {\n  if n \u003c\u003d 1 {\n    return c.Timestamp\n  }\n  t :\u003d c.Timestamp\n  n--\n  for _, p :\u003d range c.GetParents() {\n    pt :\u003d recurse(p, n)\n    if pt.Before(t) {\n      t \u003d pt\n    }\n  }\n  return t\n}\ncommitStart :\u003d recurse(head, w.numCommits)\nif commitStart.Before(start) {\n  start \u003d commitStart\n}",

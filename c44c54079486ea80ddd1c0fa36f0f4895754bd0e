      "writtenOn": "2018-07-30T20:10:44Z",
      "side": 1,
      "message": "Do we need to ensure that at least one bot is online before calling this?",
      "range": {
        "startLine": 94,
        "startChar": 13,
        "endLine": 94,
        "endChar": 32
      },
      "revId": "c44c54079486ea80ddd1c0fa36f0f4895754bd0e",

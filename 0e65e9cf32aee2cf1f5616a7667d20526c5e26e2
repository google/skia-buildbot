    {
      "unresolved": true,
      "key": {
        "uuid": "dcd450cf_ec2872bd",
        "filename": "golden/go/sql/schema/types.go",
        "patchSetId": 3
      },
      "lineNbr": 109,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-12-21T18:49:58Z",
      "side": 1,
      "message": "When we ingest the data and we see a trace for the first time, we don\u0027t want to incur the cost (and potential race condition) of loading all ignore rules and computing the ignore state right there. As such, we leave this field NULL until a process that can update this entire column safely runs.",
      "parentUuid": "bd517e23_62e0053b",
      "range": {
        "startLine": 109,
        "startChar": 10,
        "endLine": 109,
        "endChar": 22
      },
      "revId": "0e65e9cf32aee2cf1f5616a7667d20526c5e26e2",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02"
    },

        "id": 10009
      },
      "writtenOn": "2020-12-21T19:18:25Z",
      "side": 1,
      "message": "Thanks for explaining! Does that mean matches_any_ignore_rule is set to false (as opposed to NULL) when the only matching ignore rule is deleted? (This is after the background process populates this field for the first time).",
      "parentUuid": "dcd450cf_ec2872bd",
      "range": {
        "startLine": 109,
        "startChar": 10,
        "endLine": 109,
        "endChar": 22
      },
      "revId": "0e65e9cf32aee2cf1f5616a7667d20526c5e26e2",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02"

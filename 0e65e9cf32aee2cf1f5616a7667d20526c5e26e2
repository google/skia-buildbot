      "writtenOn": "2020-12-21T18:19:51Z",
      "side": 1,
      "message": "This can probably be computed from the SerializedJSON column.\n\nI believe computed columns can be used as primary keys: https://www.cockroachlabs.com/docs/v20.2/computed-columns#considerations.",
      "range": {
        "startLine": 118,
        "startChar": 0,
        "endLine": 118,
        "endChar": 60
      },
      "revId": "0e65e9cf32aee2cf1f5616a7667d20526c5e26e2",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02"
    },

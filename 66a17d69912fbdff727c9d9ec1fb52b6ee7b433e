      "writtenOn": "2020-05-11T15:04:03Z",
      "side": 1,
      "message": "Should this be called defaultCommitMsgInfoText ? or is this intended to never be different? in theory could have a commit_msg/xyz.go that never uses it.",
      "range": {
        "startLine": 18,
        "startChar": 1,

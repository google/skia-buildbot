    {
      "key": {
        "uuid": "29f9ab56_bf64726c",
        "filename": "autoroll/go/commit_msg/commit_msg.go",
        "patchSetId": 12
      },
      "lineNbr": 18,
      "author": {
        "id": 5015
      },
      "writtenOn": "2020-05-12T19:12:33Z",
      "side": 1,
      "message": "I renamed it to \"boilerplate\".  It\u0027s intended to be used verbatim in every commit message.  I started looking into how to do this cleanly, and I ended up completely changing how this package works with templates.  Now, there\u0027s a top-level \"skeleton\" template which outlines the different sections.  Each of the sections has a default definition but can be overridden.  When we build the commit message, we always execute the \"commitMsg\" template.  Other templates just override the individual sections that they want to change, though they can always override the \"commitMsg\" template itself for a completely custom message.  This results in the non-default templates being much smaller, with much better code reuse.",
      "parentUuid": "0f5bbf31_a4e2f976",
      "range": {
        "startLine": 18,
        "startChar": 1,
        "endLine": 18,
        "endChar": 18

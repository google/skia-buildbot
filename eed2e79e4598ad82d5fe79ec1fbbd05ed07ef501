      "writtenOn": "2018-06-12T18:59:59Z",
      "side": 1,
      "message": "func GetNextId(ctx context.Context, kind ds.Kind) (int64, error) {\n\t// Hit the datastore to get the current highest ID.\n\tkey :\u003d ds.NewKey(ds.CLUSTER_TELEMETRY_IDS)\n\tkey.StringId \u003d string(kind)\n\tvar nextId int64 \u003d -1\n\t_, err :\u003d ds.DS.RunInTransaction(ctx, func(tx *datastore.Transaction) error {\n\t\tif err :\u003d ds.DS.Get(key, \u0026nextId); err !\u003d nil {\n\t\t\treturn err\n\t\t}\n\t\tnextId++\n\t\t_, err :\u003d ds.DS.Put(ctx, key, nextId)\n\t\treturn err\n\t})\n\treturn nextId, err\n}",
      "range": {
        "startLine": 260,
        "startChar": 0,
        "endLine": 295,

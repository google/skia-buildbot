                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "bugs.chromium.org",
                                                        "prefix_rewrite": "/p/skia/issues/detail?id=",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "bugs.skia.org",
                                            "domains": "bugs.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/p/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "bugs.chromium.org",
                                                        "https_redirect": true
                                                    }
                                                },
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "bugs.chromium.org",
                                                        "prefix_rewrite": "/p/skia/issues/detail?id=",
                                                        "https_redirect": true
                                                    }

{
    "static_resources": {
        "listeners": [
            {
                "address": {
                    "socket_address": {
                        "address": "0.0.0.0",
                        "port_value": 8000
                    }
                },
                "filter_chains": {
                    "filters": [
                        {
                            "name": "envoy.http_connection_manager",
                            "config": {
                                "stat_prefix": "ingress_http",
                                "http_filters": [
                                    {
                                        "name": "envoy.router",
                                        "config": {}
                                    }
                                ],
                                "route_config": {
                                    "virtual_hosts": [
                                        {
                                            "name": "liveness",
                                            "domains": "*",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "direct_response": {
                                                        "status": 200,
                                                        "body": {
                                                            "inline_string": "ok"
                                                        }
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "autoroll-internal.skia.org",
                                            "domains": "autoroll-internal.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-autoroll.corp.goog",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "status-internal.skia.org ",
                                            "domains": "status-internal.skia.org ",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-status.corp.goog",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "skbug.com",

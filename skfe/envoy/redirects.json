                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-review.googlesource.com",
                                                        "prefix_rewrite": "/c/",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "review2.skia.org",
                                            "domains": "review2.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-review.googlesource.com",
                                                        "prefix_rewrite": "/c/",
                                                        "https_redirect": true
                                                    }
                                                }

                                                    "match": {
                                                        "prefix": "/json/roll"
                                                    },
                                                    "route": {
                                                        "cluster": "autoroll-google3"
                                                    }
                                                },
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-autoroll.corp.goog/r/google3-autoroll",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "gold.skia.org",
                                            "domains": "gold.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/img/"
                                                    },
                                                    "route": {
                                                        "cluster": "gold-skia-diffserver"
                                                    }
                                                },
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "route": {
                                                        "cluster": "gold-skia-skiacorrectness"
                                                    }
                                                }
                                            ]
                                        },
                                    ]
                                }
                            }
                        }
                    ]

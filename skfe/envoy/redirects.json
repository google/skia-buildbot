                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "task-scheduler-internal.skia.org",
                                            "domains": "task-scheduler-internal.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "skia-task-scheduler.corp.goog",
                                                        "https_redirect": true
                                                    }

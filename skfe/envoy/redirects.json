                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "bugs.chromium.org",
                                                        "prefix_rewrite": "/detail?id=",
                                                        "https_redirect": true
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "name": "bug.skia.org",
                                            "domains": "bug.skia.org",
                                            "routes": [
                                                {
                                                    "match": {
                                                        "prefix": "/p/"
                                                    },
                                                    "redirect": {
                                                        "host_redirect": "bugs.chromium.org",

        ],
        "clusters": [
            {
                "name": "autoroll-google3",
                "type": "STRICT_DNS",
                "connect_timeout": "1s",
                "hosts": [
                    {
                        "socket_address": {
                            "address": "autoroll-google3",
                            "port_value": 8000
                        }
                    }
                ]
            },
            {
                "name": "gold-skia-diffserver",
                "type": "STRICT_DNS",
                "connect_timeout": "1s",
                "hosts": [
                    {
                        "socket_address": {
                            "address": "gold-skia-diffserver",
                            "port_value": 8001
                        }
                    }
                ]
            },
            {
                "name": "gold-skia-skiacorrectness",
                "type": "STRICT_DNS",
                "connect_timeout": "1s",
                "hosts": [
                    {
                        "socket_address": {
                            "address": "gold-skia-skiacorrectness",
                            "port_value": 8000
                        }
                    }
                ]
            }
        ]
    }

    {
      "key": {
        "uuid": "f72eae0b_76e75c5c",
        "filename": "autoroll/go/roller/roll.go",
        "patchSetId": 1
      },
      "lineNbr": 399,
      "author": {
        "id": 5647
      },
      "writtenOn": "2018-11-01T17:21:33Z",
      "side": 1,
      "message": "If it\u0027s in the config, can we quickly turn it on or off on our side without going through the code review process? My main concern is that if our test infrastructure is flooded, we need to switch back to MERGE_METHOD_SQUASH as quickly as possible.",
      "parentUuid": "395e48b1_bad8fd65",
      "range": {
        "startLine": 399,
        "startChar": 67,
        "endLine": 399,
        "endChar": 74
      },
      "revId": "d545e4c50c91c2bedf7ebd90e4c9e44f994c14e7",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "35faa0d8_ae9524a8",
        "filename": "autoroll/go/roller/roll.go",
        "patchSetId": 1
      },
      "lineNbr": 399,
      "author": {
        "id": 5145
      },
      "writtenOn": "2018-11-01T18:25:43Z",
      "side": 1,
      "message": "No, will not be able to turn it on and off quickly on your side if it is in the config file. I will be able to push quickly though when I am online once you modify the config.\nProblem with adding ability to website to do this is that it will be difficult, the website is generic and has been generalized for all kinds of DEPS and Android rollers, adding ability to display a different option based on a config file option will be challenging.",
      "parentUuid": "f72eae0b_76e75c5c",
      "range": {
        "startLine": 399,
        "startChar": 67,
        "endLine": 399,
        "endChar": 74
      },
      "revId": "d545e4c50c91c2bedf7ebd90e4c9e44f994c14e7",

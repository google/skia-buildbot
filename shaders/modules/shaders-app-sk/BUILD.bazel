load("@infra-sk_npm//@bazel/typescript:index.bzl", "ts_library")
load("@io_bazel_rules_sass//:defs.bzl", "sass_library")
load("//infra-sk/karma_test:index.bzl", "karma_test")

package(default_visibility = ["//shaders:__subpackages__"])


##############################

ts_library(
    name = "shaders-app-sk",
    srcs = [
        "index.ts",
        "shaders-app-sk.ts",
    ],
    deps = [
        "//infra-sk/modules/ElementSk:element-sk",
        "//infra-sk/modules/theme-chooser-sk",

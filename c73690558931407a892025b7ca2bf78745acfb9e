    {
      "key": {
        "uuid": "89b6a8be_4cb0e0b0",
        "filename": "task_scheduler/go/scheduling/task_scheduler.go",
        "patchSetId": 4
      },
      "lineNbr": 1597,
      "author": {
        "id": 5015
      },
      "writtenOn": "2019-02-21T19:01:40Z",
      "side": 1,
      "message": "What if we don\u0027t presume the new task to be a success?  What if we instead assume that it has a 50/50 chance of success or failure?  We could define the \"expected\" testedness of the new task to be the midpoint between testednessFraction and 1.  If I have my math right, that would prioritize bisects higher than retries, and bisecting failures higher than successes.",
      "parentUuid": "61f07c8e_886793db",
      "range": {
        "startLine": 1597,
        "startChar": 52,
        "endLine": 1597,
        "endChar": 104
      },
      "revId": "c73690558931407a892025b7ca2bf78745acfb9e",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": false

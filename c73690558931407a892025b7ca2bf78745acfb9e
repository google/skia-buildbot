    {
      "key": {
        "uuid": "cd00aefd_67c8e97d",
        "filename": "task_scheduler/go/scheduling/task_scheduler.go",
        "patchSetId": 4
      },
      "lineNbr": 1597,
      "author": {
        "id": 5120
      },
      "writtenOn": "2019-02-21T20:47:38Z",
      "side": 1,
      "message": "Either I\u0027m misunderstanding your proposal, or my math doesn\u0027t match yours. See below.\n\nMaybe we should just simplify this and add a constant bonus for anything where stoleFrom.Status is failure or mishap?\n\nAssuming MaxAttempts\u003d2:\n\ncandidate with BL\u003d1 retrying failure with BL\u003d1\nafter: 1.0 * .75 + 0\nbefore: 1.0 * .5\nscore: .25\n\ncandidate with BL\u003d2 retrying failure with BL\u003d2\nafter: 1.5 * .75 + 0\nbefore: 1.5 * .5\nscore: .375\n\ncandidate with BL\u003d1 bisecting failure with BL\u003d2\nafter: 1.0*.75 + 1.0*.5\nbefore: 1.5*.5\nscore: .5\n\ncandidate with BL\u003d1 bisecting success with BL\u003d2\nafter: 1.0 + 1.0\nbefore: 1.5\nscore: .5\n\ncandidate with BL\u003d1 bisecting failure with BL\u003d3\nafter: 1.0*.75 + 1.5*.5\nbefore: 1.66*.5\nscore: .67\n\ncandidate with BL\u003d2 bisecting failure with BL\u003d3\nafter: 1.5*.75 + 1.0*.5\nbefore: 1.66*.5\nscore: .8\n\ncandidate with BL\u003d1 bisecting success with BL\u003d3\nafter: 1.0 + 1.5\nbefore: 1.66\nscore: .84\n\ncandidate with BL\u003d2 bisecting success with BL\u003d3\nafter: 1.5 + 1.0\nbefore: 1.66\nscore: .84",
      "parentUuid": "89b6a8be_4cb0e0b0",
      "range": {
        "startLine": 1597,
        "startChar": 52,
        "endLine": 1597,
        "endChar": 104
      },
      "revId": "c73690558931407a892025b7ca2bf78745acfb9e",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": false
    },
    {
      "key": {
        "uuid": "ee00c947_ae56d301",
        "filename": "task_scheduler/go/scheduling/task_scheduler.go",
        "patchSetId": 4
      },
      "lineNbr": 1597,
      "author": {
        "id": 5015

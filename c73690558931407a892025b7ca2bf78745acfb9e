      "writtenOn": "2019-02-21T17:35:47Z",
      "side": 1,
      "message": "If I\u0027m pedantic, this should be multiplied by testednessFraction. However, that causes retries to be scored higher than bisects. Also, this way bisecting failures gets a slight boost.",
      "range": {
        "startLine": 1597,
        "startChar": 52,
        "endLine": 1597,
        "endChar": 104
      },
      "revId": "c73690558931407a892025b7ca2bf78745acfb9e",

    {
      "key": {
        "uuid": "511872b1_e2a62653",
        "filename": "infra/bots/recipes/swarm_infra.py",
        "patchSetId": 24
      },
      "lineNbr": 38,
      "author": {
        "id": 5015
      },
      "writtenOn": "2019-05-03T13:05:28Z",
      "side": 1,
      "message": "Yep, this is a really good idea.  I don\u0027t think that would\u0027ve worked before, but now that we aren\u0027t directly editing the infra checkout inside the gopath, we should be able to let Go manage it.\n\nFTR, start_dir itself is a temporary directory and is cleaned up by Swarming after the task finishes.",
      "parentUuid": "11c0467f_339c5dba",
      "revId": "c72c23254a41400c1d075063f9819580f97ed666",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true

#!/bin/bash
# Builds and uploads a debian package for android_compile.
APPNAME=android-compiled
DESCRIPTION="Application that checks to see if Skia changes compile against the Android repo."
SYSTEMD=${APPNAME}.service

set -x -e

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="sudo install -D --verbose --backup=none --group=root --owner=root"
${INSTALL} --mode=644 -T ./sys/${APPNAME}.service ${ROOT}/etc/systemd/system/${APPNAME}.service
${INSTALL} --mode=755 -T ${GOPATH}/bin/android_compile ${ROOT}/usr/local/bin/android_compile
}

source ../bash/release.sh

        "id": 5120
      },
      "writtenOn": "2017-04-03T19:33:54Z",
      "side": 1,
      "message": "We should keep this in mind to avoid splintering FailureGroups when they are about to fall out of the window. It\u0027s probably good enough to generate FailureGroups for a larger window and then prune those that are before a smaller window.",
      "range": {
        "startLine": 96,
        "startChar": 21,
        "endLine": 98,
        "endChar": 71
      },
      "revId": "dd2689b65003958f3d15e5adddf3c74e1556e297",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": false

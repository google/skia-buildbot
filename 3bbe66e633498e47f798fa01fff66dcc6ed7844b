      "lineNbr": 94,
      "author": {
        "id": 5120
      },
      "writtenOn": "2019-02-26T22:46:21Z",
      "side": 1,
      "message": "Should this be a TODO? I can imagine someone adding os criteria to the isolate and expecting it to work.",
      "range": {
        "startLine": 94,
        "startChar": 30,
        "endLine": 94,
        "endChar": 53
      },
      "revId": "3bbe66e633498e47f798fa01fff66dcc6ed7844b",

        "id": 5395
      },
      "writtenOn": "2019-11-15T12:45:33Z",
      "side": 1,
      "message": "Good job following go/tott/594 (I need to start adopting this as well).  Might want to add an Aria tag or something to handle the selected one also.",
      "range": {
        "startLine": 110,
        "startChar": 8,
        "endLine": 110,
        "endChar": 23
      },
      "revId": "8d719b1fbeb53c7f9b9184496d2ee1706d9ab78f",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",

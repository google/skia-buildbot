      "writtenOn": "2019-05-02T17:06:03Z",
      "side": 1,
      "message": "Why isn\u0027t this in the gitstore package (or a sub-package of the same)?",
      "range": {
        "startLine": 3,
        "startChar": 0,
        "endLine": 3,
        "endChar": 13
      },
      "revId": "123f82eff35a638fac2f1048e95d54bfb2938034",

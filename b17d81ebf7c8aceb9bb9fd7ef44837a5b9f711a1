    {
      "key": {
        "uuid": "98a1cdcb_135a26e5",
        "filename": "power/go/recorder/recorder.go",
        "patchSetId": 4
      },
      "lineNbr": 15,
      "author": {
        "id": 5120
      },
      "writtenOn": "2017-09-25T15:34:24Z",
      "side": 1,
      "message": "Any implementation that is expected to persist could fail. The methods of this interface ought to return error to indicate failure.\n\nYou might consider changing this interface so that gatherer doesn\u0027t need to worry as much about handling errors. If you send this interface deltas, any failure means that the caller has to keep track of current and previous deltas for the next call. If this interface had just CurrentlyDownBots(bots []string), then it\u0027s up to the implementation to handle failures if it only wants to store deltas, or alternatively the implementation could store the entire list at each call. Either way, the caller doesn\u0027t need to keep any state about what the Recorder has already processed successfully.",
      "range": {
        "startLine": 15,
        "startChar": 1,
        "endLine": 15,
        "endChar": 29
      },
      "revId": "b17d81ebf7c8aceb9bb9fd7ef44837a5b9f711a1",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

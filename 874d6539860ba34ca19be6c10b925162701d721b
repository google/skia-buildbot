      "writtenOn": "2020-12-08T20:13:15Z",
      "side": 1,
      "message": "We don\u0027t currently have any autorollers that do this, but it should be possible.  Alternatively, whoever uploads the image could also create a CL to update the digest.",
      "range": {
        "startLine": 3104,
        "startChar": 30,
        "endLine": 3105,
        "endChar": 52
      },
      "revId": "874d6539860ba34ca19be6c10b925162701d721b",

    {
      "key": {
        "uuid": "e00957eb_5a3f5eb2",
        "filename": "go/task_driver/examples/basic/basic.go",
        "patchSetId": 3
      },
      "lineNbr": 24,
      "author": {
        "id": 5015
      },
      "writtenOn": "2018-10-11T14:25:16Z",
      "side": 1,
      "message": "That\u0027s correct.  I\u0027ve thought about declaring these in the task_driver package, but my recent experience trying to dig through Chrome Infra code (which makes extensive use of CLI and flag helpers) has been extremely frustrating since it\u0027s very non-obvious which flags are actually part of the program.  One of the central ideas of this framework is that I want the individual task drivers to be as simple and readable as possible.",
      "parentUuid": "0dd09963_d9c9773d",
      "range": {
        "startLine": 24,
        "startChar": 4,
        "endLine": 24,
        "endChar": 38
      },
      "revId": "9a53274257a50255a3cbbf1f5d3a8ea2a37d17a1",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

      "writtenOn": "2020-03-24T13:33:54Z",
      "side": 1,
      "message": "suggestion: I think this would read better with a helper test function.\n\ntest :\u003d func(name, diffPixels, threshold, error string) {...}\n\ntest(\"no parameters specified\", \"\", \"\", \"parameter not found\")\ntest(\"missing first parameter\", \"0\", \"\", \"parameter not found\")\ntest(\"missing second parameter\", \"\", \"0\", \"parameter not found\")\ntest(\"one invalid parameter\", \"not integer\", \"0\", \"parsing integer value\")\ntest(\"other invalid parameter\", \"2\", \"not integer\", \"parsing integer value\")\ntest(\"both invalid parameters\", \"not integer\", \"not integer\", \"parsing integer value\")",
      "range": {
        "startLine": 1459,
        "startChar": 1,
        "endLine": 1459,
        "endChar": 6
      },
      "revId": "381fc8bcfe03c450570e37c5a87b1a0123ec3e4e",

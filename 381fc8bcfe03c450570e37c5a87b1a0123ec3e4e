    {
      "key": {
        "uuid": "c31b3d64_6e4107cd",
        "filename": "gold-client/go/goldclient/goldclient_test.go",
        "patchSetId": 11
      },
      "lineNbr": 1459,
      "author": {
        "id": 10009
      },
      "writtenOn": "2020-03-24T19:00:36Z",
      "side": 1,
      "message": "I\u0027d rather not do this, for two reasons:\n- I don\u0027t like that the two fields are positional arguments, which doesn\u0027t tell you which one is which.\n- The distinction between a missing parameter value (i.e. not found in the optionalKeys map) vs. an empty value (i.e. the empty string) is important to this test, thus using string arguments would require passing a sentinel string to represent a missing value, and some conditional logic to correctly build the optionalKeys map in the test function.",
      "parentUuid": "5a53a413_31b4ece7",

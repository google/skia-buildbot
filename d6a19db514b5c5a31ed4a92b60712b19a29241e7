      "writtenOn": "2017-07-28T02:59:17Z",
      "side": 1,
      "message": "OK, I see this here now. Is this the thing re: how to do this in Go? Module level variables seem like basically only slightly more controlled/manageable versions of globals. Do we really not want to pass a cache around explicitly to those methods that mutate it?",
      "range": {
        "startLine": 34,
        "startChar": 1,
        "endLine": 34,
        "endChar": 11
      },
      "revId": "d6a19db514b5c5a31ed4a92b60712b19a29241e7",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true

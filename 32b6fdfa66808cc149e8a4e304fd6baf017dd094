      "writtenOn": "2018-09-28T13:29:07Z",
      "side": 1,
      "message": "If this is anything like index.lock, we shouldn\u0027t just delete it without knowing what\u0027s going on. Deleting lockfiles should be a one-time thing that we do on server (or docker container) startup.",
      "range": {
        "startLine": 13,
        "startChar": 13,
        "endLine": 13,
        "endChar": 26
      },
      "revId": "32b6fdfa66808cc149e8a4e304fd6baf017dd094",

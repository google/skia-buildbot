      "writtenOn": "2020-01-27T16:28:03Z",
      "side": 1,
      "message": "SunnyDay, to me, means that none of the dependencies of the code produce an error.  Most of the tests in web_test are SunnyDay, because I was adding them as a part of getting familiar with the code base and had to prioritize breadth over depth.",
      "parentUuid": "1fb97e5b_25956ccd",
      "range": {
        "startLine": 94,
        "startChar": 17,
        "endLine": 94,
        "endChar": 25
      },
      "revId": "cebe2b48bb21a5ffb0dea2d8a3c60d1904c7494f",

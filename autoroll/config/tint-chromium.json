{
  "childDisplayName": "Tint",
  "contacts": [
    "radial-bots+tint-roll@google.com"
  ],
  "isInternal": false,
  "ownerPrimary": "borenet",
  "ownerSecondary": "rmistry",
  "parentDisplayName": "Chromium",
  "parentWaterfall": "https://build.chromium.org",
  "rollerName": "tint-chromium-autoroll",
  "serviceAccount": "chromium-autoroll@skia-public.iam.gserviceaccount.com",
  "sheriff": [
    "https://chrome-ops-rotation-proxy.appspot.com/current/grotation:webgpu-sheriff"
  ],
  "sheriffBackup": [
    "radial-bots+tint-roll@google.com"
  ],
  "commitMsg": {
    "bugProject": "chromium",
    "childLogURLTmpl": "https://dawn.googlesource.com/tint.git/+log/{{.RollingFrom}}..{{.RollingTo}}",
    "cqExtraTrybots": [
      "luci.chromium.try:dawn-linux-x64-deps-rel",
      "luci.chromium.try:dawn-mac-x64-deps-rel",
      "luci.chromium.try:dawn-win10-x64-deps-rel",
      "luci.chromium.try:dawn-win10-x86-deps-rel"
    ],
    "includeLog": true,
    "includeRevisionCount": true,
    "includeTbrLine": true,
    "includeTests": true,
    "template": "default"
  },
  "gerrit": {
    "url": "https://chromium-review.googlesource.com",
    "project": "chromium/src",
    "config": "chromium"
  },
  "noCheckoutDEPSRepoManager": {
    "childBranch": "main",
    "childPath": "",
    "parentBranch": "master",
    "parentRepo": "https://chromium.googlesource.com/chromium/src.git",
    "gerrit": {
      "url": "https://chromium-review.googlesource.com",
      "project": "chromium/src",
      "config": "chromium"
    },
    "childRepo": "https://dawn.googlesource.com/tint.git"
  },
  "kubernetes": {
    "cpu": "1",
    "memory": "2Gi",
    "readinessFailureThreshold": "10",
    "readinessInitialDelaySeconds": "30",
    "readinessPeriodSeconds": "30"
  },
  "maxRollFrequency": "24h",
  "supportsManualRolls": true
}

#!/bin/bash
# Creates a build for the autoroll backend, either in Kubernetes or for Skia Push.

set -x -e

# Load the config file and determine which script to call.
CONFIG_FILE="$1"
if [ -z "${CONFIG_FILE}" ]; then
  echo "Usage: $0 <path to config file> <message>"
  exit 1
fi
shift

IS_KUBERNETES=$(cat $CONFIG_FILE | python -c "import sys, json; print '1' if json.load(sys.stdin).get('kubernetes') is not None else ''")
echo $IS_KUBERNETES

if [ -z "$IS_KUBERNETES" ]; then
  ./deprecated_build_backend_release ${CONFIG_FILE} $@
else
  ./build_docker_backend_release ${CONFIG_FILE} $@
fi

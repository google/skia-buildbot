      "writtenOn": "2018-05-07T19:01:43Z",
      "side": 1,
      "message": "Package-private constants shouldn\u0027t be uppercase.\n\n(Actually, our Go code is not following the Go style guide when we use UPPER_CASE_CONSTANTS. Go convention is CamelCasePublicConstants and camelCasePrivateConstants.)",
      "parentUuid": "97d4a20e_6fb41543",
      "range": {
        "startLine": 171,
        "startChar": 6,
        "endLine": 171,
        "endChar": 20
      },

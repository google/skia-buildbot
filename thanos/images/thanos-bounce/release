#!/bin/bash

set -x -e

APPNAME=thanos-bounce

IMAGE=$(dirname "$0")

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="install -D --verbose --backup=none"

# Add the dockerfile.
${INSTALL} --mode=644 -T ${IMAGE}/Dockerfile   ${ROOT}/Dockerfile
}

source ../bash/docker_build.sh

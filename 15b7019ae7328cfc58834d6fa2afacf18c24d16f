      "writtenOn": "2019-05-24T18:50:31Z",
      "side": 1,
      "message": "What happens if the PR is manually closed in the middle of a dry run?",
      "parentUuid": "1c03ee48_28f722a4",
      "range": {
        "startLine": 167,
        "startChar": 0,
        "endLine": 167,
        "endChar": 43
      },
      "revId": "15b7019ae7328cfc58834d6fa2afacf18c24d16f",

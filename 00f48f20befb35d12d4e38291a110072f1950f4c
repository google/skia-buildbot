      "writtenOn": "2020-04-03T18:49:55Z",
      "side": 1,
      "message": "A quality of life improvement would be to have a function that pings the metadata server before Launch. That way, if we fail to hit the metadata server, we know before swarming fails with somewhat cryptic 403 errors.",
      "range": {
        "startLine": 63,
        "startChar": 2,
        "endLine": 63,
        "endChar": 13
      },
      "revId": "00f48f20befb35d12d4e38291a110072f1950f4c",

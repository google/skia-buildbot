      "writtenOn": "2020-04-03T18:49:55Z",
      "side": 1,
      "message": "Does this mean if we try to do a graceful shutdown of the swarming machine, it will automatically restart? Is this desireable?",
      "range": {
        "startLine": 175,
        "startChar": 1,
        "endLine": 175,
        "endChar": 4
      },
      "revId": "00f48f20befb35d12d4e38291a110072f1950f4c",

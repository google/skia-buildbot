    {
      "key": {
        "uuid": "db5fb88c_b5b71132",
        "filename": "sk8s/go/bot_config/swarming/swarming.go",
        "patchSetId": 43
      },
      "lineNbr": 175,
      "author": {
        "id": 5205
      },
      "writtenOn": "2020-04-03T21:03:39Z",
      "side": 1,
      "message": "Shutting down a swarming machine should be something that Machine State handles and then gets threaded into bot_config.",
      "parentUuid": "7562c797_4366b2ce",
      "range": {
        "startLine": 175,
        "startChar": 1,
        "endLine": 175,
        "endChar": 4
      },
      "revId": "00f48f20befb35d12d4e38291a110072f1950f4c",

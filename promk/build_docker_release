#!/bin/bash
# Builds and uploads a docker package for alertmanager_webhooks.
APPNAME=alertmanager_webhooks

set -x -e

# Copy files into the right locations in ${ROOT}.
copy_release_files()
{
INSTALL="install -D --verbose --backup=none"
${INSTALL} --mode=644 -T Dockerfile                          ${ROOT}/Dockerfile
${INSTALL} --mode=755 -T ${GOPATH}/bin/alertmanager_webhooks ${ROOT}/bin/alertmanager_webhooks
}

source ../bash/docker_build.sh

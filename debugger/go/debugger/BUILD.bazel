load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "go_default_library",
    srcs = ["main.go"],
    importpath = "go.skia.org/infra/debugger/go/debugger",
    visibility = ["//visibility:private"],
    deps = [
        "//debugger/go/instances:go_default_library",
        "//go/common:go_default_library",
        "//go/httputils:go_default_library",
        "//go/sklog:go_default_library",
        "//go/util:go_default_library",
        "@com_github_fiorix_go_web//autogzip:go_default_library",
        "@com_github_gorilla_mux//:go_default_library",
    ],
)

go_binary(
    name = "debugger",
    embed = [":go_default_library"],
    visibility = ["//visibility:public"],
)

        "id": 5015
      },
      "writtenOn": "2018-11-27T14:27:25Z",
      "side": 1,
      "message": "I\u0027d like for that not to be the case :)  I think we should be able to figure out a way to guarantee accuracy under the assumption that pubsub works as expected.",
      "parentUuid": "ac8d983c_7cd29c6f",
      "range": {
        "startLine": 134,
        "startChar": 5,
        "endLine": 134,
        "endChar": 21
      },
      "revId": "e7432b044c406b60b4c7e0b2a9131d0d82f1e000",

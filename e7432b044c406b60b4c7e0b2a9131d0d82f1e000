        "id": 5120
      },
      "writtenOn": "2018-11-26T18:47:21Z",
      "side": 1,
      "message": "I think we need to handle the case where we get a message for a subscriber after the subscriber calls stopTrackingModifiedData.",
      "range": {
        "startLine": 79,
        "startChar": 14,
        "endLine": 79,
        "endChar": 28
      },
      "revId": "e7432b044c406b60b4c7e0b2a9131d0d82f1e000",

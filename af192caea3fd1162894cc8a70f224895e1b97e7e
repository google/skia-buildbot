    {
      "key": {
        "uuid": "3e6a8e21_8981eeef",
        "filename": "task_driver/go/td/step.go",
        "patchSetId": 2
      },
      "lineNbr": 64,
      "author": {
        "id": 5015
      },
      "writtenOn": "2018-11-09T19:00:59Z",
      "side": 1,
      "message": "Unfortunately, if we used the error message, we could treat different error instances as if they\u0027re the same.  I\u0027d be more concerned about two errors which happen to have the same message than about illegal map keys.\n\nIt\u0027s possible that I just haven\u0027t thought of the right way to do this yet, and I\u0027m definitely open to alternative suggestions.  Determining whether a step failed because of one of its children (and therefore should inherit its infra/non-infra failure status) turns out to be kind of tricky.",
      "parentUuid": "d98697a9_e0f6e97b",
      "range": {
        "startLine": 64,
        "startChar": 22,
        "endLine": 64,
        "endChar": 27
      },
      "revId": "af192caea3fd1162894cc8a70f224895e1b97e7e",

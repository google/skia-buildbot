      "writtenOn": "2018-10-10T20:03:53Z",
      "side": 1,
      "message": "Why \u0026err?",
      "revId": "320e47702b2df9cd17d33e31ca179ad922c8d991",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",

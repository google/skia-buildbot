      "message": "FTR I think something like this would give us an always-correct solution:\n\nconst current \u003d this.branchHeads.map((bh) \u003d\u003e this.commits[bh.hash]);\nconst sorted \u003d [];\nwhile (current.length \u003e 0) {\n  let nextCommit \u003d undefined;\n  let nextCommitIndex \u003d undefined;\n  current.forEach((commit, index) \u003d\u003e {\n    if (!nextCommit || nextCommit.timestamp \u003c commit.timestamp) {\n      nextCommit \u003d commit;\n      nextCommitIndex \u003d index;\n    }\n  });\n  sorted.push(nextCommit);\n  current.splice(nextCommitIndex, 1);\n  nextCommit.parents.forEach((hash) \u003d\u003e {\n    current.push(this.commits[hash]);\n  });\n}",

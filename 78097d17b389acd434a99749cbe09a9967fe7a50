      "key": {
        "uuid": "417918c1_2def6c0d",
        "filename": "swarming_logger/go/swarming_logger/main.go",
        "patchSetId": 3
      },
      "lineNbr": 51,
      "author": {
        "id": 5120
      },
      "writtenOn": "2017-04-26T17:29:27Z",
      "side": 1,
      "message": "I\u0027m not sure PubSub will work well for this purpose, for a couple reasons:\n1. This handler will be called every time the task status changes. That means we\u0027ll see the beginning of the output in the logs at least twice, once after the task starts running and once when the task is finished.\n2. PubSub is not exactly guaranteed delivery -- if this handler returns false too many times (e.g. swarming is temporarily down or overloaded) for the same PubSub message, that message gets dropped on the floor. (I suspect that there are other cases where messages get lost also.)\n\nI\u0027m happy with this as v0.5, since I can\u0027t think of a more robust solution that doesn\u0027t require either remembering a lot of things or querying for a lot of things.",
      "range": {
        "startLine": 51,
        "startChar": 22,
        "endLine": 51,
        "endChar": 42
      },
      "revId": "78097d17b389acd434a99749cbe09a9967fe7a50",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },

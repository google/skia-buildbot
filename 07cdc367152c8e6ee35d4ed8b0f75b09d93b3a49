      },
      "writtenOn": "2018-06-22T13:57:44Z",
      "side": 1,
      "message": "Are we assuming no grand-parents or more distant ancestors?",
      "range": {
        "startLine": 202,
        "startChar": 38,
        "endLine": 202,
        "endChar": 51
      },
      "revId": "07cdc367152c8e6ee35d4ed8b0f75b09d93b3a49",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
